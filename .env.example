# memcp — environment variables
# Copy to .env and fill in values. Only MEM0_API_BASE and MEM0_API_KEY are required.

# mem0 backend connection (required)
MEM0_API_BASE=https://your-mem0-instance.example.com
MEM0_API_KEY=your-mem0-api-key

# Auth token clients must present (optional — unset = open/dev mode)
SHIM_AUTH_TOKEN=

# Fixed user ID for all calls (default: default_user)
MEM0_USER_ID=default_user

# Server bind (optional)
MEMCP_HOST=0.0.0.0
MEMCP_PORT=8080

# Logging (optional)
MEMCP_LOG_LEVEL=INFO
MEMCP_LOG_FORMAT=json
